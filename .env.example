SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
APP_PUBLIC_ORIGIN=http://localhost:3000

# 代理与 Cookie 安全
# 本地开发默认不信任转发头；若生产部署在可信反向代理后，可设为 true 并配置 TRUST_PROXY_CIDRS
TRUST_PROXY=false
TRUST_PROXY_CIDRS=
# 本地 http 请保持 false；线上 https 建议 true
COOKIE_SECURE=false
# 用户登录态 Cookie 有效期（秒），默认 24h
USER_SESSION_TTL_SEC=86400
# Auth 网络容错（用于 /api/user-auth/me 与 requireUserAuth）
SUPABASE_AUTH_TIMEOUT_MS=3200
SUPABASE_AUTH_RETRY_MAX=2
SUPABASE_AUTH_RETRY_DELAY_MS=180

# Brevo SMTP（用于在 Supabase 控制台启用 Custom SMTP；web_server 不直接发邮件）
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your_login@smtp-brevo.com
BREVO_SMTP_KEY=xsmtpsib-xxxx
BREVO_SMTP_SENDER_EMAIL=noreply@example.com
BREVO_SMTP_SENDER_NAME=QuickRec

# Pairing / session security
PAIR_CODE_LENGTH=6
# 与 PAIR_CODE_TTL_SEC 等价，优先生效（秒）
PAIR_TTL_SECONDS=3600
PAIR_CODE_TTL_SEC=3600
PAIR_MAX_FAILS=30
PAIR_LOCK_SECONDS=180
PAIR_STATUS_SESSION_ISSUE_WINDOW_SEC=180
# 设备会话有效期（秒）：开发期默认长期（约10年），避免已配对设备反复重新配对
DEVICE_SESSION_TTL_SEC=315360000

# 安全风控（接口防刷/限流）
# 含义：在 window 秒内允许最多 max 次请求（当前为开发期宽松配置，生产建议收紧）
RL_PAIR_CODE_MAX=10000
RL_PAIR_CODE_WINDOW_SEC=60
RL_PAIR_STATUS_MAX=10000
RL_PAIR_STATUS_WINDOW_SEC=60
RL_BIND_MAX=10000
RL_BIND_WINDOW_SEC=300
RL_AUTH_MAX=10000
RL_AUTH_WINDOW_SEC=300

# 手机->服务端 批量分片上传
# 单次请求批量有效负载上限（字节）：1024KB = 1048576
WATCH_UPLOAD_BATCH_MAX_BYTES=1048576
# 单次请求最多携带分片数（建议与手表分片大小配合，默认16）
WATCH_UPLOAD_BATCH_MAX_CHUNKS=16

# 会议纪要任务超时回收（毫秒）
# queued/running 超过该阈值将自动标记为 failed，避免页面长期显示“纪要生成中”
MEETING_JOB_STALE_MS=1800000

# Cloudflare Turnstile
TURNSTILE_ENABLED=false
NEXT_PUBLIC_TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_VERIFY_TIMEOUT_MS=5000
TURNSTILE_LOGIN_REQUIRED=true
TURNSTILE_REGISTER_REQUIRED=true
TURNSTILE_FORGOT_REQUIRED=true
TURNSTILE_RESEND_REQUIRED=false

# 管理员邮箱白名单（逗号分隔）
ADMIN_EMAILS=1442661932@qq.com

# 非管理员会议纪要生成额度（默认每人 10 次）
NON_ADMIN_MEETING_NOTES_LIMIT=10
NON_ADMIN_MEETING_NOTES_LIMIT_MESSAGE=测试版美人人10次会议纪要生成功能
