SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Pairing / session security
PAIR_CODE_LENGTH=6
PAIR_CODE_TTL_SEC=300
PAIR_STATUS_SESSION_ISSUE_WINDOW_SEC=180
DEVICE_SESSION_TTL_SEC=2592000

# 安全风控（接口防刷/限流）
# 含义：在 window 秒内允许最多 max 次请求（当前为开发期宽松配置，生产建议收紧）
RL_PAIR_CODE_MAX=10000
RL_PAIR_CODE_WINDOW_SEC=60
RL_PAIR_STATUS_MAX=10000
RL_PAIR_STATUS_WINDOW_SEC=60
RL_BIND_MAX=10000
RL_BIND_WINDOW_SEC=300
RL_AUTH_MAX=10000
RL_AUTH_WINDOW_SEC=300

# Cloudflare Turnstile
TURNSTILE_ENABLED=false
NEXT_PUBLIC_TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_VERIFY_TIMEOUT_MS=5000
TURNSTILE_LOGIN_REQUIRED=true
TURNSTILE_REGISTER_REQUIRED=true
TURNSTILE_FORGOT_REQUIRED=true
TURNSTILE_RESEND_REQUIRED=false
