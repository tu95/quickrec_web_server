{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "24"
  },
  "steps": {
    "install": {
      "commands": [
        "if [ -f package-lock.json ]; then npm ci --no-audit --no-fund; else npm install --no-audit --no-fund; fi"
      ]
    },
    "build": {
      "inputs": [
        {
          "step": "install"
        }
      ],
      "commands": [
        "npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "npm run start"
  }
}
